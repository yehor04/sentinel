# Sentinel environment variables — copy to .env, fill in, never commit .env.

# === Required for full cascade ===

GEMINI_API_KEY=                    # https://aistudio.google.com/apikey
FEATHERLESS_API_KEY=               # https://featherless.ai (hackathon coupon)

# === Deployment ===

SENTINEL_DOMAIN=sentinel.example.com
SENTINEL_VULTR_HOST=root@xxx.xxx.xxx.xxx

# === Daemon tuning (optional) ===

SENTINEL_PORT=7777
SENTINEL_DB_PATH=~/.sentinel/sentinel.db
SENTINEL_DAEMON_URL=http://127.0.0.1:7777/detect
SENTINEL_TIMEOUT_SECS=0.2          # hook fail-open budget
SENTINEL_HOOK_LOG=~/.sentinel/hook.log

# === Model selection (optional; defaults in configs/models.yaml) ===

SENTINEL_L3_MODEL=gemini-2.5-flash
SENTINEL_EMBED_MODEL=Qwen/Qwen2.5-0.5B-Instruct
