# Single-stage build for the Sentinel FastAPI daemon.
# Day-2 hardening: runs as non-root `sentinel` user with UID/GID 10001.

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app/backend

WORKDIR /app

# Pinned dependency set. Day-3 adds:
#   - numpy: Layer 2 cosine
#   - diskcache: persistent embedding LRU
#   - google-generativeai: Layer 3 Gemini Flash verifier
#   - openai: Featherless OpenAI-compatible client (transport bottle for embeddings)
RUN pip install --no-cache-dir \
        "fastapi>=0.111,<0.130" \
        "uvicorn[standard]>=0.30,<0.40" \
        "pydantic>=2.5,<3" \
        "httpx>=0.27,<0.30" \
        "structlog>=24.4,<26" \
        "rapidfuzz>=3.10,<4" \
        "pyyaml>=6,<7" \
        "numpy>=2.0,<3" \
        "diskcache>=5.6,<6" \
        "google-generativeai>=0.8,<1"

# Create dedicated non-root user with a stable UID/GID so volume permissions
# stay deterministic across rebuilds. /var/sentinel pre-created so the named
# docker volume inherits sentinel:sentinel ownership on first mount.
RUN groupadd --system --gid 10001 sentinel \
    && useradd --system --uid 10001 --gid sentinel \
       --no-create-home --shell /usr/sbin/nologin sentinel \
    && mkdir -p /var/sentinel \
    && chown -R sentinel:sentinel /var/sentinel /app

# Copy app + configs + dashboard. Done AFTER user creation so chown covers all.
COPY --chown=sentinel:sentinel backend/ ./backend/
COPY --chown=sentinel:sentinel configs/ ./configs/
COPY --chown=sentinel:sentinel frontend/ ./frontend/

USER sentinel

EXPOSE 7777

CMD ["uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "7777", "--workers", "1"]
