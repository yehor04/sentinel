# Caddy reverse proxy for Sentinel — auto-TLS via Let's Encrypt.
# Reads SENTINEL_DOMAIN from the environment (set via shell or compose env_file).

{$SENTINEL_DOMAIN} {
    encode gzip zstd

    # SSE events stream — flush_interval -1 disables buffering for live dashboard
    handle /events {
        reverse_proxy backend:7777 {
            flush_interval -1
        }
    }

    # Daemon health probe
    handle /health {
        reverse_proxy backend:7777
    }

    # Cascade entrypoint
    handle /detect {
        reverse_proxy backend:7777
    }

    # All other API paths (benchmark results, traces, etc.)
    handle /api/* {
        reverse_proxy backend:7777
    }

    # /history endpoint for dashboard stats
    handle /history {
        reverse_proxy backend:7777
    }

    # Dashboard + all other paths → FastAPI (serves frontend/index.html via StaticFiles)
    handle {
        reverse_proxy backend:7777
    }

    log {
        output stdout
        format json
        level INFO
    }
}
